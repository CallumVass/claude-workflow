#!/usr/bin/env bash
set -euo pipefail

CW_VERSION="0.1.0"
CW_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
SCRIPTS_DIR="$CW_ROOT/scripts"

CW_BACKEND="${CW_BACKEND:-claude}"
CW_MODEL="${CW_MODEL:-}"

# Inline color setup (doesn't source lib.sh)
if [ -n "${NO_COLOR:-}" ] || [ ! -t 2 ]; then
  _C="" _R="" _G="" _Y=""
else
  _C=$'\033[36m' _R=$'\033[0m' _G=$'\033[32m' _Y=$'\033[33m'
fi

usage() {
  cat <<'EOF'
cw — claude-workflow CLI

Autonomous software delivery pipeline using Claude Code.
Takes a project from PRD to merged PRs.

Pipeline:
  PRD.md → prd-qa → create-issues → implement → merged PRs

Commands:
  prd-qa                  Refine PRD via multi-agent loop (critic → architect → integrator)
                          Requires PRD.md in current directory.

  create-issue "<desc>"   Interactive QA to refine a feature idea into a single issue.
                          Explores codebase, asks clarifying questions, creates issue.

  create-issues           Decompose PRD.md into vertical-slice GitHub issues.
                          Requires PRD.md. Creates issues labeled "auto-generated".

  implement               Implement open issues autonomously.
                          Plan → TDD → CI → code review → merge, in dependency order.
                          Parallelizes independent issues via git worktrees.

  review <PR#>            Code review (reviewer → judge pipeline).
    review --branch <br>  Review branch vs main.
    review <PR#> --skip-checks  Skip lint/type/test checks.

  evolve                  Pipeline retrospective: analyze failures + PRs → improve agents.
                          Creates a PR against claude-workflow with patches.

  init                    Bootstrap current project (.claude/CLAUDE.md + hooks.json).
  sync                    Update ~/.claude (+ opencode if installed).
  setup                   Install 'cw' to ~/.local/bin (run once per machine).
  version                 Show version.

Environment variables:
  CW_BACKEND        Agent backend        (default: claude; options: claude, opencode)
  CW_MODEL          Model override       (default: backend default)

  TEST_CMD          Test command         (default: pnpm test)
  CHECK_CMD         Full CI check        (default: pnpm check)
  INSTALL_CMD       Dependency install   (default: pnpm install --frozen-lockfile)
  CI_FIX_RETRIES    CI fix attempts      (default: 2)
  REVIEW_MAX_CYCLES Review→fix cycles    (default: 2)
  MAX_PARALLEL      Concurrent issues    (default: 3)

Orchestrators (use as your agent in Claude Code / opencode):
  implementation-orchestrator    Plan → implement (TDD)
  review-orchestrator            Deterministic checks → review → judge
  prd-orchestrator               Critic → architect → integrator loop
  issue-creation-orchestrator    Validate PRD → create GitHub issues
  ci-fix-orchestrator            Diagnose → fix → verify CI

Agents (usable standalone via: claude --agent <name>):
  planner, implementor, synthesizer, retrospective, code-reviewer,
  review-judge, ci-fixer, issue-creator, single-issue-creator,
  prd-integrator, prd-critic, prd-architect

All commands run in the current working directory.
Requires: claude or opencode (based on CW_BACKEND), gh (GitHub CLI), jq
EOF
}

check_prerequisites() {
  local missing=()
  local backend_cmd="claude"
  [ "$CW_BACKEND" = "opencode" ] && backend_cmd="opencode"
  for cmd in "$backend_cmd" gh jq git; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done
  if [ ${#missing[@]} -gt 0 ]; then
    echo "${_Y}✗${_R} missing required commands: ${missing[*]}" >&2
    echo "  See: cw --help" >&2
    exit 1
  fi
}

check_placeholders() {
  local project_md=".claude/CLAUDE.md"
  if [ -f "$project_md" ] && grep -qE '\{\{[A-Z_]+\}\}' "$project_md"; then
    echo "${_Y}✗${_R} .claude/CLAUDE.md has unfilled placeholders:" >&2
    grep -oE '\{\{[A-Z_]+\}\}' "$project_md" | sort -u | sed 's/^/  /' >&2
    echo "  Run: \$EDITOR $project_md" >&2
    exit 1
  fi
}

# Agents invoked directly by scripts (top-level in opencode).
# All others are subagent-only.
TOPLEVEL_AGENTS="single-issue-creator issue-creation-orchestrator prd-orchestrator review-orchestrator implementation-orchestrator ci-fix-orchestrator implementor synthesizer retrospective"

# Convert a Claude agent .md to OpenCode format.
# Strips name/skills/tools from frontmatter, sets mode based on top-level list.
convert_agent_for_opencode() {
  local src="$1"
  local dest_dir="$2"
  local filename agent_name agent_mode
  filename=$(basename "$src")
  agent_name="${filename%.md}"

  agent_mode="subagent"
  for tl in $TOPLEVEL_AGENTS; do
    [ "$tl" = "$agent_name" ] && { agent_mode="all"; break; }
  done

  awk -v mode="$agent_mode" -f "$CW_ROOT/scripts/convert-agent-opencode.awk" "$src" > "$dest_dir/$filename"
}

cmd_sync() {
  local claude_home="${CLAUDE_HOME:-$HOME/.claude}"

  echo "${_C}●${_R} Syncing to $claude_home ..."

  # Agents
  mkdir -p "$claude_home/agents"
  cp "$CW_ROOT/agents/"*.md "$claude_home/agents/"
  echo "  ${_G}✓${_R} agents: $(ls "$CW_ROOT/agents/"*.md | wc -l) files"

  # Skills
  mkdir -p "$claude_home/skills"
  for skill_dir in "$CW_ROOT/skills"/*/; do
    skill_name=$(basename "$skill_dir")
    mkdir -p "$claude_home/skills/$skill_name"
    cp -r "$skill_dir"* "$claude_home/skills/$skill_name/"
  done
  echo "  ${_G}✓${_R} skills: $(ls -d "$CW_ROOT/skills"/*/ | wc -l) dirs"

  # Global CLAUDE.md — managed block between markers
  local global_md="$claude_home/CLAUDE.md"
  local template="$CW_ROOT/templates/CLAUDE.md.global"
  local begin_marker="<!-- BEGIN claude-workflow -->"
  local end_marker="<!-- END claude-workflow -->"

  if [ ! -f "$global_md" ]; then
    # No file — create from template
    cp "$template" "$global_md"
    echo "  ${_G}✓${_R} CLAUDE.md: created"
  elif grep -qF "$begin_marker" "$global_md"; then
    # Markers exist — replace the managed block
    local tmpfile
    tmpfile=$(mktemp)
    # Print lines before BEGIN, then new template, then lines after END
    awk -v begin="$begin_marker" -v end="$end_marker" '
      $0 == begin { skip=1; next }
      $0 == end { skip=0; next }
      !skip { print }
    ' "$global_md" > "$tmpfile"
    # Insert template content at the top (before any user content)
    cat "$template" "$tmpfile" > "$global_md"
    rm -f "$tmpfile"
    echo "  ${_G}✓${_R} CLAUDE.md: updated managed block"
  else
    # File exists but no markers — prepend template
    local tmpfile
    tmpfile=$(mktemp)
    cat "$template" > "$tmpfile"
    echo "" >> "$tmpfile"
    cat "$global_md" >> "$tmpfile"
    mv "$tmpfile" "$global_md"
    echo "  ${_G}✓${_R} CLAUDE.md: prepended (first sync — markers added)"
  fi

  # OpenCode agents — convert if opencode is installed
  if command -v opencode >/dev/null 2>&1; then
    local opencode_agents="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/agents"
    mkdir -p "$opencode_agents"
    local count=0
    for agent_file in "$CW_ROOT/agents/"*.md; do
      convert_agent_for_opencode "$agent_file" "$opencode_agents"
      count=$((count + 1))
    done
    echo "  ${_G}✓${_R} opencode agents: $count files → $opencode_agents"
  fi

  echo "${_G}✓${_R} Done."
}

cmd_init() {
  local template="$CW_ROOT/templates/CLAUDE.md.project"
  local hooks_template="$CW_ROOT/templates/hooks.json"
  local target_dir=".claude"
  local target_md="$target_dir/CLAUDE.md"
  local target_hooks="$target_dir/hooks.json"

  mkdir -p "$target_dir"

  # CLAUDE.md
  if [ -f "$target_md" ]; then
    echo "  ${_C}●${_R} $target_md already exists, skipping."
  else
    cp "$template" "$target_md"
    echo "  ${_G}✓${_R} created $target_md (edit placeholders: {{PROJECT_NAME}}, {{CHECK_CMD}}, etc.)"
  fi

  # hooks.json
  if [ -f "$target_hooks" ]; then
    echo "  ${_C}●${_R} $target_hooks already exists, skipping."
  else
    cp "$hooks_template" "$target_hooks"
    echo "  ${_G}✓${_R} created $target_hooks"
  fi

  # AGENTS.md — OpenCode's equivalent of .claude/CLAUDE.md
  local agents_md="AGENTS.md"
  if [ ! -f "$agents_md" ]; then
    cp "$template" "$agents_md"
    echo "  ${_G}✓${_R} created $agents_md (OpenCode project instructions — edit same placeholders)"
  else
    echo "  ${_C}●${_R} $agents_md already exists, skipping."
  fi

  # Ensure claude-workflow artifacts are gitignored
  local gitignore=".gitignore"
  local cw_entries=("LEARNINGS.md" "logs/" "progress.log" "failures/")
  local added=()

  if [ ! -f "$gitignore" ]; then
    {
      echo "# claude-workflow (local-only, not committed)"
      for entry in "${cw_entries[@]}"; do echo "$entry"; done
    } > "$gitignore"
    echo "  ${_G}✓${_R} created .gitignore"
  else
    for entry in "${cw_entries[@]}"; do
      if ! grep -qxF "$entry" "$gitignore"; then
        added+=("$entry")
      fi
    done
    if [ ${#added[@]} -gt 0 ]; then
      echo "" >> "$gitignore"
      echo "# claude-workflow (local-only, not committed)" >> "$gitignore"
      for entry in "${added[@]}"; do echo "$entry" >> "$gitignore"; done
      echo "  ${_G}✓${_R} updated .gitignore: added ${added[*]}"
    fi
  fi
}

cmd_setup() {
  local target="${1:-$HOME/.local/bin}"
  local self
  self="$(readlink -f "${BASH_SOURCE[0]}")"

  mkdir -p "$target"
  ln -sf "$self" "$target/cw"
  echo "Linked: $target/cw → $self"

  if ! echo "$PATH" | tr ':' '\n' | grep -qF "$target"; then
    echo ""
    echo "NOTE: $target is not on your PATH."
    echo "Add to your shell profile:  export PATH=\"$target:\$PATH\""
  fi
}

if [ $# -eq 0 ]; then
  usage
  exit 0
fi

case "$1" in
  -h|--help)
    usage
    ;;
  version|--version|-v)
    echo "cw $CW_VERSION"
    ;;
  init)
    cmd_init
    ;;
  setup)
    shift
    cmd_setup "$@"
    ;;
  sync)
    cmd_sync
    ;;
  prd-qa)
    check_prerequisites
    check_placeholders
    shift
    exec "$SCRIPTS_DIR/prd-qa.sh" "$@"
    ;;
  create-issue)
    check_prerequisites
    check_placeholders
    shift
    exec "$SCRIPTS_DIR/create-issue.sh" "$@"
    ;;
  create-issues)
    check_prerequisites
    check_placeholders
    shift
    exec "$SCRIPTS_DIR/create-issues.sh" "$@"
    ;;
  implement)
    check_prerequisites
    check_placeholders
    shift
    exec "$SCRIPTS_DIR/implement-issues.sh" "$@"
    ;;
  review)
    check_prerequisites
    shift
    exec "$SCRIPTS_DIR/review.sh" "$@"
    ;;
  evolve)
    check_prerequisites
    shift
    exec "$SCRIPTS_DIR/evolve.sh" "$@"
    ;;
  *)
    echo "${_Y}✗${_R} Unknown command: $1" >&2
    echo "  Run 'cw --help' for usage." >&2
    exit 1
    ;;
esac
